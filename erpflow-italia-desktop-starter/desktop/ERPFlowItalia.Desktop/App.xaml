<Application x:Class="ERPFlowItalia.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#EAF1FB"/>
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#D5E1F2"/>
        <SolidColorBrush x:Key="SidebarTitleBrush" Color="#12304A"/>
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#4A6278"/>
        <SolidColorBrush x:Key="SidebarButtonForegroundBrush" Color="#183B56"/>
        <SolidColorBrush x:Key="SidebarButtonHoverBrush" Color="#D6E6FA"/>
        <SolidColorBrush x:Key="SidebarButtonPressedBrush" Color="#C3D9F5"/>
        <SolidColorBrush x:Key="SidebarButtonActiveBrush" Color="#BFD8FA"/>
        <SolidColorBrush x:Key="SidebarButtonActiveBorderBrush" Color="#7AA7E8"/>
        <SolidColorBrush x:Key="SidebarButtonActiveForegroundBrush" Color="#102A43"/>
        <SolidColorBrush x:Key="SidebarCalloutBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource SidebarButtonForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
