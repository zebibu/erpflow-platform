<Window x:Class="ERPFlowItalia.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERPFlow Italia - Desktop ERP"
        Height="820"
        Width="1380"
        MinHeight="650"
        MinWidth="1120"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Border Style="{StaticResource CardBorderStyle}" Padding="0" CornerRadius="32" Background="#FCFCFA">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="312"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PrimaryBrush}"
                        BorderBrush="{StaticResource SidebarBorderBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="32,0,0,32">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="56" Height="56" CornerRadius="18" Background="#F0B429">
                                <TextBlock Text="EF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#102A43"/>
                            </Border>
                            <TextBlock Text="ERPFlow Italia"
                                       Foreground="{StaticResource SidebarTitleBrush}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,18,0,0"/>
                            <TextBlock Text="Operational workspace for warehouse, trade, stock, and invoicing teams."
                                       Foreground="{StaticResource SidebarTextBrush}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,28,0,0">
                            <TextBlock Text="NAVIGATION"
                                       Style="{StaticResource SectionCaptionStyle}"
                                       Foreground="#7FA5C6"
                                       Margin="2,0,0,10"/>
                            <Button x:Name="DashboardButton" Content="Dashboard" Style="{StaticResource SidebarNavButtonStyle}" Click="Dashboard_Click"/>
                            <Button x:Name="ProductsButton" Content="Products" Style="{StaticResource SidebarNavButtonStyle}" Click="Products_Click"/>
                            <Button x:Name="WarehousesButton" Content="Warehouses" Style="{StaticResource SidebarNavButtonStyle}" Click="Warehouses_Click"/>
                            <Button x:Name="StockButton" Content="Stock" Style="{StaticResource SidebarNavButtonStyle}" Click="Stock_Click"/>
                            <Button x:Name="OrdersButton" Content="Orders" Style="{StaticResource SidebarNavButtonStyle}" Click="Orders_Click"/>
                            <Button x:Name="CustomersButton" Content="Customers" Style="{StaticResource SidebarNavButtonStyle}" Click="Customers_Click"/>
                            <Button x:Name="SuppliersButton" Content="Suppliers" Style="{StaticResource SidebarNavButtonStyle}" Click="Suppliers_Click"/>
                            <Button x:Name="InvoicesButton" Content="Invoices" Style="{StaticResource SidebarNavButtonStyle}" Click="Invoices_Click"/>
                            <Button x:Name="ReportsButton" Content="Reports" Style="{StaticResource SidebarNavButtonStyle}" Click="Reports_Click"/>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Background="{StaticResource SidebarCalloutBrush}"
                                BorderBrush="#2C5A7D"
                                BorderThickness="1"
                                Padding="18"
                                CornerRadius="22"
                                Margin="0,24,0,0">
                            <StackPanel>
                                <TextBlock Text="TODAY'S FOCUS"
                                           Style="{StaticResource SectionCaptionStyle}"
                                           Foreground="#B9D3E8"/>
                                <TextBlock Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0"
                                           Text="Keep inventory, order flow, and invoicing aligned across one workspace."
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="#FFF9F2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="CONTROL CENTER"
                                               Style="{StaticResource SectionCaptionStyle}"
                                               Foreground="{StaticResource AccentStrongBrush}"/>
                                    <TextBlock x:Name="PageTitle"
                                               Text="Dashboard"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,8,0,0"/>
                                    <TextBlock x:Name="PageSubtitle"
                                               Text="Overview of warehouse, stock, sales, invoices and company operations."
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Background="#102A43"
                                        CornerRadius="20"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="LIVE OPS"
                                                   Style="{StaticResource SectionCaptionStyle}"
                                                   Foreground="#9FC4E2"/>
                                        <TextBlock Text="Warehouse and sales pipeline synced through the API layer."
                                                   Foreground="White"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                            <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource SurfaceMutedBrush}" Padding="16" Margin="0,0,0,14">
                                <StackPanel Width="166">
                                    <TextBlock Text="SESSION"
                                               Style="{StaticResource SectionCaptionStyle}"/>
                                    <TextBlock x:Name="SessionNameText"
                                               Text="Desktop ERP"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,6,0,0"/>
                                    <TextBlock x:Name="SessionRoleText"
                                               Text="Admin"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button Content="Refresh Data"
                                    MinWidth="166"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="Refresh_Click"/>
                            <Button Content="Sign Out"
                                    MinWidth="166"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="SignOut_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="26" Padding="18" BorderBrush="#E1E8EF" BorderThickness="1">
                        <ContentControl x:Name="MainContent"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
