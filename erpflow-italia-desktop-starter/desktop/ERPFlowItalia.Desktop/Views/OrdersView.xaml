<UserControl x:Class="ERPFlowItalia.Desktop.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,16">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Width="220" Margin="0,0,12,12">
                    <TextBlock Text="Customer" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CustomerComboBox" DisplayMemberPath="CompanyName" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Width="220" Margin="0,0,12,12">
                    <TextBlock Text="Product" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ProductComboBox" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Width="100" Margin="0,0,12,12">
                    <TextBlock Text="Quantity" Margin="0,0,0,4"/>
                    <TextBox x:Name="QuantityTextBox" Text="1"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,20,0,12">
                    <Button Content="Create Order" Width="120" Margin="0,0,8,0" Click="CreateOrder_Click"/>
                    <Button Content="Confirm Selected" Width="130" Margin="0,0,8,0" Click="ConfirmSelected_Click"/>
                    <Button Content="Delete Selected" Width="130" Click="DeleteSelected_Click"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <DataGrid x:Name="OrdersGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Order #" Binding="{Binding OrderNumber}" Width="150"/>
                <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="80"/>
                <DataGridTextColumn Header="Net" Binding="{Binding NetAmount, StringFormat=€{0:N2}}" Width="110"/>
                <DataGridTextColumn Header="VAT" Binding="{Binding VatAmount, StringFormat=€{0:N2}}" Width="110"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=€{0:N2}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>