<UserControl x:Class="ERPFlowItalia.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="REPORT DIREZIONALI" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                <TextBlock Text="Valore di magazzino per analisi finanziaria e operativa" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                <TextBlock Text="Il report mette in relazione disponibilita, SKU e valore economico per ogni sede logistica." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="ReportsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Articolo" Binding="{Binding Product}" Width="*"/>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="120"/>
                <DataGridTextColumn Header="Magazzino" Binding="{Binding Warehouse}" Width="180"/>
                <DataGridTextColumn Header="Quantita" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Valore stock" Binding="{Binding StockValue, StringFormat=€{0:N2}}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>