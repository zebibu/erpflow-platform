<UserControl x:Class="ERPFlowItalia.Desktop.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Products list from ASP.NET Core API" VerticalAlignment="Center"/>
                <Button Content="Load Products" Width="140" Margin="20,0,0,0" Click="Load_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="ProductsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="120"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160"/>
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="120"/>
                <DataGridTextColumn Header="VAT %" Binding="{Binding VatRate}" Width="80"/>
                <DataGridTextColumn Header="Min Stock" Binding="{Binding MinimumStockLevel}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
