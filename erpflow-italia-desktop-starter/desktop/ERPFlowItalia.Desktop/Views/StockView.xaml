<UserControl x:Class="ERPFlowItalia.Desktop.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16" Background="#FFF9F2">
            <StackPanel>
                <TextBlock Text="CONTROLLO GIACENZE" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                <TextBlock Text="Disponibilita reale per articolo e magazzino" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                <TextBlock Text="La vista evidenzia prodotti sotto scorta per aiutare riordino, trasferimenti e priorita operative." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="StockGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Articolo" Binding="{Binding Product}" Width="*"/>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="120"/>
                <DataGridTextColumn Header="Magazzino" Binding="{Binding Warehouse}" Width="180"/>
                <DataGridTextColumn Header="Giacenza" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Scorta minima" Binding="{Binding MinimumStockLevel}" Width="120"/>
                <DataGridCheckBoxColumn Header="Sotto scorta" Binding="{Binding IsLowStock}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
