<UserControl x:Class="ERPFlowItalia.Desktop.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataGrid x:Name="StockGrid"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Background="White">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Product" Binding="{Binding Product}" Width="*"/>
            <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="120"/>
            <DataGridTextColumn Header="Warehouse" Binding="{Binding Warehouse}" Width="180"/>
            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
            <DataGridTextColumn Header="Minimum Stock" Binding="{Binding MinimumStockLevel}" Width="120"/>
            <DataGridCheckBoxColumn Header="Low Stock" Binding="{Binding IsLowStock}" Width="100"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
