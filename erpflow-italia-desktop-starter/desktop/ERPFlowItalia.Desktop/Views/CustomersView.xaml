<UserControl x:Class="ERPFlowItalia.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ANAGRAFICA CLIENTE" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                <TextBlock Text="Scheda cliente per amministrazione, vendita e fatturazione elettronica" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                <TextBlock Text="Raccogli i riferimenti anagrafici usati nelle pratiche commerciali italiane: ragione sociale, Partita IVA, Codice Fiscale, provincia e recapiti." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,18" TextWrapping="Wrap"/>

                <WrapPanel>
                    <StackPanel Width="220" Margin="0,0,12,12">
                        <TextBlock Text="Ragione sociale" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="CompanyNameTextBox"/>
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="Partita IVA" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="VatNumberTextBox"/>
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="Codice Fiscale" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="FiscalCodeTextBox"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="0,0,12,12">
                        <TextBlock Text="Email amministrazione" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="EmailTextBox"/>
                    </StackPanel>
                    <StackPanel Width="160" Margin="0,0,12,12">
                        <TextBlock Text="Telefono" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="PhoneTextBox"/>
                    </StackPanel>
                    <StackPanel Width="160" Margin="0,0,12,12">
                        <TextBlock Text="Citta" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="CityTextBox"/>
                    </StackPanel>
                    <StackPanel Width="100" Margin="0,0,12,12">
                        <TextBlock Text="Provincia" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="ProvinceTextBox"/>
                    </StackPanel>
                    <StackPanel Width="100" Margin="0,0,12,12">
                        <TextBlock Text="CAP" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="20100"/>
                    </StackPanel>
                    <StackPanel Width="140" Margin="0,0,12,12">
                        <TextBlock Text="Paese" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="CountryTextBox"/>
                    </StackPanel>
                </WrapPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Nuovo cliente" MinWidth="120" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButtonStyle}" Click="New_Click"/>
                    <Button Content="Salva anagrafica" MinWidth="132" Margin="0,0,8,0" Style="{StaticResource PrimaryActionButtonStyle}" Click="Save_Click"/>
                    <Button Content="Elimina" MinWidth="96" Style="{StaticResource SecondaryActionButtonStyle}" Click="Delete_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="CustomersGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="CustomersGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cliente" Binding="{Binding CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Partita IVA" Binding="{Binding VatNumber}" Width="150"/>
                <DataGridTextColumn Header="Codice Fiscale" Binding="{Binding FiscalCode}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                <DataGridTextColumn Header="Telefono" Binding="{Binding Phone}" Width="130"/>
                <DataGridTextColumn Header="Citta" Binding="{Binding City}" Width="120"/>
                <DataGridTextColumn Header="Provincia" Binding="{Binding Province}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>