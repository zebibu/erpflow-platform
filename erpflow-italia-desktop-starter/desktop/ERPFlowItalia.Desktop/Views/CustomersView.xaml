<UserControl x:Class="ERPFlowItalia.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Customer details" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <WrapPanel>
                    <StackPanel Width="220" Margin="0,0,12,12">
                        <TextBlock Text="Company" Margin="0,0,0,4"/>
                        <TextBox x:Name="CompanyNameTextBox"/>
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="VAT Number" Margin="0,0,0,4"/>
                        <TextBox x:Name="VatNumberTextBox"/>
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="Fiscal Code" Margin="0,0,0,4"/>
                        <TextBox x:Name="FiscalCodeTextBox"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="0,0,12,12">
                        <TextBlock Text="Email" Margin="0,0,0,4"/>
                        <TextBox x:Name="EmailTextBox"/>
                    </StackPanel>
                    <StackPanel Width="160" Margin="0,0,12,12">
                        <TextBlock Text="Phone" Margin="0,0,0,4"/>
                        <TextBox x:Name="PhoneTextBox"/>
                    </StackPanel>
                    <StackPanel Width="160" Margin="0,0,12,12">
                        <TextBlock Text="City" Margin="0,0,0,4"/>
                        <TextBox x:Name="CityTextBox"/>
                    </StackPanel>
                    <StackPanel Width="100" Margin="0,0,12,12">
                        <TextBlock Text="Province" Margin="0,0,0,4"/>
                        <TextBox x:Name="ProvinceTextBox"/>
                    </StackPanel>
                    <StackPanel Width="140" Margin="0,0,12,12">
                        <TextBlock Text="Country" Margin="0,0,0,4"/>
                        <TextBox x:Name="CountryTextBox"/>
                    </StackPanel>
                </WrapPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="New" Width="90" Margin="0,0,8,0" Click="New_Click"/>
                    <Button Content="Save" Width="90" Margin="0,0,8,0" Click="Save_Click"/>
                    <Button Content="Delete" Width="90" Click="Delete_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="CustomersGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="CustomersGrid_SelectionChanged"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="*"/>
                <DataGridTextColumn Header="VAT Number" Binding="{Binding VatNumber}" Width="150"/>
                <DataGridTextColumn Header="Fiscal Code" Binding="{Binding FiscalCode}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="130"/>
                <DataGridTextColumn Header="City" Binding="{Binding City}" Width="120"/>
                <DataGridTextColumn Header="Province" Binding="{Binding Province}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>