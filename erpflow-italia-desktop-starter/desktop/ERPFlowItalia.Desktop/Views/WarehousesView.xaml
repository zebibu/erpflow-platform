<UserControl x:Class="ERPFlowItalia.Desktop.Views.WarehousesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="RETE MAGAZZINI" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                <TextBlock Text="Hub logistici e presidi territoriali" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                <TextBlock Text="Monitora sedi operative, indirizzi e capillarita logistica per servire clienti in tutta Italia." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="WarehousesGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Magazzino" Binding="{Binding Name}" Width="220"/>
                <DataGridTextColumn Header="Area" Binding="{Binding Location}" Width="160"/>
                <DataGridTextColumn Header="Indirizzo" Binding="{Binding Address}" Width="*"/>
                <DataGridTextColumn Header="Citta" Binding="{Binding City}" Width="120"/>
                <DataGridTextColumn Header="Provincia" Binding="{Binding Province}" Width="100"/>
                <DataGridTextColumn Header="CAP" Binding="{Binding PostalCode}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
