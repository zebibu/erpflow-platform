<UserControl x:Class="ERPFlowItalia.Desktop.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,16">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Width="240" Margin="0,0,12,12">
                    <TextBlock Text="Order without invoice" Margin="0,0,0,4"/>
                    <ComboBox x:Name="OrderComboBox" DisplayMemberPath="OrderNumber" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Width="180" Margin="0,0,12,12">
                    <TextBlock Text="Payment status" Margin="0,0,0,4"/>
                    <ComboBox x:Name="PaymentStatusComboBox"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,20,0,12">
                    <Button Content="Create Invoice" Width="120" Margin="0,0,8,0" Click="CreateInvoice_Click"/>
                    <Button Content="Save Status" Width="110" Margin="0,0,8,0" Click="SaveStatus_Click"/>
                    <Button Content="Delete Selected" Width="130" Click="DeleteSelected_Click"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <DataGrid x:Name="InvoicesGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="InvoicesGrid_SelectionChanged"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="160"/>
                <DataGridTextColumn Header="Order #" Binding="{Binding Order.OrderNumber}" Width="150"/>
                <DataGridTextColumn Header="Customer" Binding="{Binding Order.Customer.CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Status" Binding="{Binding PaymentStatus}" Width="120"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=€{0:N2}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>