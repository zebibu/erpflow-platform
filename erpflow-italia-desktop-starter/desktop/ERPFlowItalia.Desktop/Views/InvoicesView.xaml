<UserControl x:Class="ERPFlowItalia.Desktop.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="FATTURE" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                <TextBlock Text="Controllo emissione e stato pagamento" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                <TextBlock Text="Genera una fattura da un ordine confermato e aggiorna lo stato pagamento per il controllo amministrativo." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,18" TextWrapping="Wrap"/>

                <WrapPanel VerticalAlignment="Center">
                <StackPanel Width="240" Margin="0,0,12,12">
                    <TextBlock Text="Ordine senza fattura" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="OrderComboBox" DisplayMemberPath="OrderNumber" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Width="180" Margin="0,0,12,12">
                    <TextBlock Text="Stato pagamento" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="PaymentStatusComboBox"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,20,0,12">
                    <Button Content="Crea fattura" MinWidth="118" Margin="0,0,8,0" Style="{StaticResource PrimaryActionButtonStyle}" Click="CreateInvoice_Click"/>
                    <Button Content="Salva stato" MinWidth="112" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButtonStyle}" Click="SaveStatus_Click"/>
                    <Button Content="Elimina selezionata" MinWidth="150" Style="{StaticResource SecondaryActionButtonStyle}" Click="DeleteSelected_Click"/>
                </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="InvoicesGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="InvoicesGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fattura" Binding="{Binding InvoiceNumber}" Width="160"/>
                <DataGridTextColumn Header="Ordine" Binding="{Binding Order.OrderNumber}" Width="150"/>
                <DataGridTextColumn Header="Cliente" Binding="{Binding Order.Customer.CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Data" Binding="{Binding InvoiceDate, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Pagamento" Binding="{Binding PaymentStatus}" Width="120"/>
                <DataGridTextColumn Header="Totale" Binding="{Binding TotalAmount, StringFormat=€{0:N2}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>