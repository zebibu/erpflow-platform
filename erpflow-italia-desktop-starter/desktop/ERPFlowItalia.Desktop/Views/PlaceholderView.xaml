<UserControl x:Class="ERPFlowItalia.Desktop.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.6*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="MODULE PREVIEW"
                           Style="{StaticResource SectionCaptionStyle}"
                           Foreground="{StaticResource AccentStrongBrush}"/>
                <TextBlock Text="This workflow is staged for the next build cycle."
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="MessageText"
                           Margin="0,14,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Background="#102A43"
                BorderBrush="#214B69"
                Margin="12,0,0,0">
            <StackPanel>
                <TextBlock Text="NEXT IMPLEMENTATION"
                           Style="{StaticResource SectionCaptionStyle}"
                           Foreground="#9FC4E2"/>
                <TextBlock Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="16">
                    Add data grids, structured forms, API service methods, CRUD actions, and role-based permissions to move this module from scaffold to production workflow.
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
