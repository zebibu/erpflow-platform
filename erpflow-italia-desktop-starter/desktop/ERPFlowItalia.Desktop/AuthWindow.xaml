<Window x:Class="ERPFlowItalia.Desktop.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERPFlow Italia - Accesso"
        Height="840"
        Width="1260"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Border Style="{StaticResource CardBorderStyle}" Padding="0" CornerRadius="32" Background="#FCFCFA">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PrimaryBrush}"
                        CornerRadius="32,0,0,32"
                        Padding="32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="62" Height="62" CornerRadius="20" Background="#F0B429">
                                <TextBlock Text="EF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#102A43"/>
                            </Border>
                            <TextBlock Text="ERPFlow Italia"
                                       Foreground="White"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Margin="0,22,0,0"/>
                            <TextBlock Text="Accesso riservato a team amministrativi, commerciali e logistici." 
                                       Foreground="#B9D3E8"
                                       Margin="0,10,0,0"
                                       FontSize="16"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,28,0,0">
                            <TextBlock Text="Piattaforma operativa per distributori e PMI italiane" 
                                       Foreground="White"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Gestisci anagrafiche, ordini, giacenze, fatture e flussi di magazzino in un'unica postazione desktop con linguaggio e processi coerenti con il contesto italiano."
                                       Foreground="#DCE8F3"
                                       Margin="0,18,0,0"
                                       FontSize="17"
                                       TextWrapping="Wrap"/>

                            <UniformGrid Columns="1" Margin="0,24,0,0">
                                <Border Style="{StaticResource CardBorderStyle}" Background="#143652" BorderBrush="#2A597A" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Accesso ruoli" Style="{StaticResource SectionCaptionStyle}" Foreground="#9FC4E2"/>
                                        <TextBlock Text="Admin, Manager, Sales Team e Warehouse Worker" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#143652" BorderBrush="#2A597A">
                                    <StackPanel>
                                        <TextBlock Text="Contesto Italia" Style="{StaticResource SectionCaptionStyle}" Foreground="#9FC4E2"/>
                                        <TextBlock Text="Partita IVA, Codice Fiscale, CAP, province e processi B2B tipici della distribuzione locale" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Background="{StaticResource SidebarCalloutBrush}"
                                BorderBrush="#2C5A7D"
                                BorderThickness="1"
                                Padding="18"
                                CornerRadius="22">
                            <StackPanel>
                                <TextBlock Text="SUGGERIMENTO DEMO" Style="{StaticResource SectionCaptionStyle}" Foreground="#B9D3E8"/>
                                <TextBlock Text="Se non hai ancora un account, registrane uno dal pannello a destra e poi accedi subito al gestionale." Foreground="White" Margin="0,10,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="SignInTabButton"
                                Content="Sign In"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Margin="0,0,10,0"
                                Click="ShowSignIn_Click"/>
                        <Button x:Name="SignUpTabButton"
                                Grid.Column="1"
                                Content="Sign Up"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="ShowSignUp_Click"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,24,0,0">
                        <Border x:Name="SignInPanel" Style="{StaticResource CardBorderStyle}" Background="#FFFDF9">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="ACCESSO OPERATIVO" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                                    <TextBlock Text="Entra nel gestionale" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,0"/>
                                    <TextBlock Text="Usa il tuo indirizzo aziendale e la password dell'account ERPFlow Italia." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>

                                    <StackPanel Margin="0,24,0,0">
                                        <TextBlock Text="Email aziendale" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="LoginEmailTextBox"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}"/>
                                        <PasswordBox x:Name="LoginPasswordBox"/>
                                    </StackPanel>

                                    <TextBlock x:Name="LoginStatusText"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,16,0,0"
                                               TextWrapping="Wrap"/>

                                    <Button Content="Accedi al gestionale"
                                            Margin="0,24,0,0"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Click="SignIn_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border x:Name="SignUpPanel" Style="{StaticResource CardBorderStyle}" Background="#FFFDF9" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="REGISTRAZIONE" Style="{StaticResource SectionCaptionStyle}" Foreground="{StaticResource AccentStrongBrush}"/>
                                    <TextBlock Text="Crea un nuovo accesso" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,0"/>
                                    <TextBlock Text="Attiva un account per il team amministrativo, commerciale o logistico e accedi subito al desktop ERP." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>

                                    <Grid Margin="0,24,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Nome e cognome" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="RegisterFullNameTextBox"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Email aziendale" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="RegisterEmailTextBox"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Ruolo operativo" Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="RoleComboBox" SelectedIndex="0">
                                                <ComboBoxItem Content="Admin"/>
                                                <ComboBoxItem Content="Manager"/>
                                                <ComboBoxItem Content="SalesTeam"/>
                                                <ComboBoxItem Content="WarehouseWorker"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}"/>
                                            <PasswordBox x:Name="RegisterPasswordBox"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="Conferma password" Style="{StaticResource FieldLabelStyle}"/>
                                        <PasswordBox x:Name="ConfirmPasswordBox"/>
                                    </StackPanel>

                                    <TextBlock x:Name="RegisterStatusText"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,16,0,0"
                                               TextWrapping="Wrap"/>

                                    <Button Content="Crea account"
                                            Margin="0,24,0,0"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Click="SignUp_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>